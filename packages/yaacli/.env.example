# YAACLI CLI environment variables
# Copy this file to packages/yaacli/.env for workspace development,
# or to .env in your current working directory when launching yaacli.
# YAACLI loads these values at startup and passes them through process env.
# SDK and tool variables such as YA_AGENT_*, YA_AGENT_BROWSER_USE_*, GOOGLE_SEARCH_API_KEY,
# and FIRECRAWL_API_KEY can also live in this file. Use packages/ya-agent-sdk/.env.example
# as the reference list for those variables.

# =============================================================================
# Display
# =============================================================================

# YAACLI_CODE_THEME=dark
# YAACLI_SHOW_TOKEN_USAGE=true
# YAACLI_SHOW_ELAPSED_TIME=true

# =============================================================================
# Browser
# =============================================================================

# YAACLI_CDP_URL=auto
# YAACLI_BROWSER_IMAGE=zenika/alpine-chrome:latest
# YAACLI_BROWSER_TIMEOUT=30

# =============================================================================
# Steering
# =============================================================================

# YAACLI_STEERING_ENABLED=true
# YAACLI_STEERING_PREFIX=>

# =============================================================================
# Session
# =============================================================================

# YAACLI_SESSION_DIR=.yaacli
# YAACLI_AUTO_SAVE_HISTORY=true
# YAACLI_AUTO_RESTORE=true

# =============================================================================
# Agent Stream Recovery
# =============================================================================

# YAACLI_AGENT_STREAM_RESUME_ON_ERROR=true
# YAACLI_AGENT_STREAM_RESUME_MAX_ATTEMPTS=2
# YAACLI_AGENT_STREAM_RESUME_PROMPT=The previous streaming model request failed before the agent finished. Continue the task from the available conversation history. Avoid repeating completed work.

# =============================================================================
# Performance
# =============================================================================

# YAACLI_PERF=1

# =============================================================================
# Provider API Keys
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
