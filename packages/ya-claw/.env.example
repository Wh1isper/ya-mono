# YA Claw runtime environment variables
# Copy this file to packages/ya-claw/.env and uncomment the variables you need.
# SDK and tool environment variables live in packages/ya-agent-sdk/.env.example.

# =============================================================================
# YA Claw Configuration (YA_CLAW_ prefix)
# =============================================================================

# YA_CLAW_ENVIRONMENT=development
# YA_CLAW_HOST=127.0.0.1
# YA_CLAW_PORT=9042
# YA_CLAW_PUBLIC_BASE_URL=http://127.0.0.1:9042
# YA_CLAW_API_TOKEN=replace-with-a-long-random-token
# YA_CLAW_AUTO_MIGRATE=true
# YA_CLAW_DATA_DIR=~/.ya-claw/data
# YA_CLAW_WORKSPACE_ROOT=~/.ya-claw/workspace
# Default SQLite path: ~/.ya-claw/ya_claw.sqlite3
# YA_CLAW_DATABASE_URL=postgresql+psycopg://ya_claw:ya_claw@localhost:15433/ya_claw
# YA_CLAW_DATABASE_ECHO=false
# YA_CLAW_DATABASE_POOL_SIZE=5
# YA_CLAW_DATABASE_MAX_OVERFLOW=10
# YA_CLAW_DATABASE_POOL_RECYCLE_SECONDS=3600
# YA_CLAW_WEB_DIST_DIR=apps/ya-claw-web/dist
# YA_CLAW_DEFAULT_PROFILE=default
# Bundled profile seed lives at packages/ya-claw/profiles.yaml
# YA_CLAW_PROFILE_SEED_FILE=packages/ya-claw/profiles.yaml
# YA_CLAW_AUTO_SEED_PROFILES=true
# YA_CLAW_WORKSPACE_PROVIDER_BACKEND=local
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_IMAGE=python:3.11
# Global MCP config defaults to ~/.ya-claw/mcp.json
# YA_CLAW_MCP_CONFIG_FILE=~/.ya-claw/mcp.json
# Project MCP config defaults to .ya-claw/mcp.json inside each workspace
# YA_CLAW_PROJECT_MCP_CONFIG_PATH=.ya-claw/mcp.json
# YA_CLAW_EXECUTION_CONTEXT_WINDOW=200000

# =============================================================================
# Model Provider / SDK Environment
# =============================================================================
# YA Claw startup now exports non-YA_CLAW variables from packages/ya-claw/.env
# into the process environment. Keep provider keys here for local development.

# GATEWAY_API_KEY=replace-with-your-gateway-key
# GATEWAY_BASE_URL=https://gateway.example.test
