# ya-agent-sdk Environment Variables
# Copy this file to .env and uncomment the variables you need

# =============================================================================
# Web Search API Keys
# =============================================================================

# GOOGLE_SEARCH_API_KEY=your_google_search_api_key
# GOOGLE_SEARCH_CX=your_google_search_cx
# TAVILY_API_KEY=your_tavily_api_key
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# =============================================================================
# Image Search API Keys
# =============================================================================

# PIXABAY_API_KEY=your_pixabay_api_key
# RAPIDAPI_API_KEY=your_rapidapi_key

# =============================================================================
# Web Scraping API Keys
# =============================================================================

# FIRECRAWL_API_KEY=your_firecrawl_api_key

# =============================================================================
# Agent Configuration (YA_AGENT_ prefix)
# =============================================================================

# YA_AGENT_IMAGE_UNDERSTANDING_MODEL=gpt-4o-mini
# YA_AGENT_IMAGE_UNDERSTANDING_MODEL_SETTINGS=anthropic_off
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL_SETTINGS=anthropic_off
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL_SETTINGS=gemini_thinking_level_low
# YA_AGENT_COMPACT_MODEL=gemini-2.0-flash

# =============================================================================
# Browser Use Configuration (YA_AGENT_BROWSER_USE_ prefix)
# =============================================================================

# YA_AGENT_BROWSER_USE_MAX_RETRIES=3
# YA_AGENT_BROWSER_USE_PREFIX=browser_use_
# YA_AGENT_BROWSER_USE_ALWAYS_USE_NEW_PAGE=false
# YA_AGENT_BROWSER_USE_AUTO_CLEANUP_PAGE=false

# =============================================================================
# YA Claw Configuration (YA_CLAW_ prefix)
# =============================================================================

# YA_CLAW_ENVIRONMENT=development
# YA_CLAW_HOST=127.0.0.1
# YA_CLAW_PORT=9042
# YA_CLAW_PUBLIC_BASE_URL=http://127.0.0.1:9042
# YA_CLAW_AUTO_MIGRATE=true
# YA_CLAW_DATABASE_URL=postgresql+psycopg://ya_claw:ya_claw@localhost:15433/ya_claw
# YA_CLAW_REDIS_URL=redis://localhost:16380/0
# YA_CLAW_DATABASE_ECHO=false
# YA_CLAW_DATABASE_POOL_SIZE=5
# YA_CLAW_DATABASE_MAX_OVERFLOW=10
# YA_CLAW_DATABASE_POOL_RECYCLE_SECONDS=3600
# YA_CLAW_WEB_DIST_DIR=apps/ya-claw-web/dist
