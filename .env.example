# ya-agent-sdk Environment Variables
# Copy this file to .env and uncomment the variables you need

# =============================================================================
# Web Search API Keys
# =============================================================================

# Google Custom Search API
# Get your key at: https://developers.google.com/custom-search/v1/introduction
# GOOGLE_SEARCH_API_KEY=your_google_search_api_key
# GOOGLE_SEARCH_CX=your_google_search_cx

# Tavily Search API
# Get your key at: https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key

# Brave Search API
# Get your key at: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# =============================================================================
# Image Search API Keys
# =============================================================================

# Pixabay API (stock images)
# Get your key at: https://pixabay.com/api/docs/
# PIXABAY_API_KEY=your_pixabay_api_key

# RapidAPI (real-time image search)
# Get your key at: https://rapidapi.com/
# RAPIDAPI_API_KEY=your_rapidapi_key

# =============================================================================
# Web Scraping API Keys
# =============================================================================

# Firecrawl API
# Get your key at: https://firecrawl.dev/
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# =============================================================================
# Agent Configuration (YA_AGENT_ prefix)
# =============================================================================

# Model for image understanding when native vision is unavailable
# YA_AGENT_IMAGE_UNDERSTANDING_MODEL=gpt-4o-mini
# YA_AGENT_IMAGE_UNDERSTANDING_MODEL_SETTINGS=anthropic_off

# Model for video understanding when native capability is unavailable
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL_SETTINGS=anthropic_off

# Model for audio understanding when native capability is unavailable
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL_SETTINGS=gemini_thinking_level_low

# Model for compact when native capability is unavailable
# YA_AGENT_COMPACT_MODEL=gemini-2.0-flash

# =============================================================================
# Browser Use Configuration (YA_AGENT_BROWSER_USE_ prefix)
# =============================================================================

# Maximum retry attempts for tool calls
# YA_AGENT_BROWSER_USE_MAX_RETRIES=3

# Tool name prefix
# YA_AGENT_BROWSER_USE_PREFIX=browser_use_

# Force create new page instead of reusing existing
# YA_AGENT_BROWSER_USE_ALWAYS_USE_NEW_PAGE=false

# Automatically close created page targets on context exit
# YA_AGENT_BROWSER_USE_AUTO_CLEANUP_PAGE=false

# =============================================================================
# YA Agent Platform Configuration (YA_PLATFORM_ prefix)
# =============================================================================

# Core server settings
# YA_PLATFORM_ENVIRONMENT=development
# YA_PLATFORM_HOST=127.0.0.1
# YA_PLATFORM_PORT=9042
# YA_PLATFORM_PUBLIC_BASE_URL=http://127.0.0.1:9042
# YA_PLATFORM_AUTO_MIGRATE=true

# Persistence infrastructure
# YA_PLATFORM_DATABASE_URL=postgresql+psycopg://ya_platform:ya_platform@localhost:15433/ya_platform
# YA_PLATFORM_REDIS_URL=redis://localhost:16380/0
# YA_PLATFORM_DATABASE_ECHO=false
# YA_PLATFORM_DATABASE_POOL_SIZE=5
# YA_PLATFORM_DATABASE_MAX_OVERFLOW=10
# YA_PLATFORM_DATABASE_POOL_RECYCLE_SECONDS=3600

# Frontend bundle path for combined backend + web serving
# YA_PLATFORM_WEB_DIST_DIR=apps/ya-agent-platform-web/dist
